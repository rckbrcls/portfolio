{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": false
    }
  },
  "rewrites": [
    {
      "source": "/api/sparky/appcast.xml",
      "destination": "https://rckbrcls.github.io/sparky/appcast.xml"
    },
    {
      "source": "/api/page-forge/appcast.xml",
      "destination": "https://rckbrcls.github.io/page-forge/appcast.xml"
    }
  ],
  "headers": [
    {
      "source": "/api/sparky/install",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    },
    {
      "source": "/api/page-forge/install",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    }
  ]
}
